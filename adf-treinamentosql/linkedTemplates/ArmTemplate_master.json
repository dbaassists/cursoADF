{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-treinamentosql"
		},
		"LS_AZURE_SQL_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_AZURE_SQL'"
		},
		"LS_BLOB_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_BLOB'"
		},
		"LS_FILE_ONPREMISE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_FILE_ONPREMISE'"
		},
		"LS_FILE_ONPREMISE_PARAM_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_FILE_ONPREMISE_PARAM'"
		},
		"LS_SQLSERVER_ONPREMISE_PARAM_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_SQLSERVER_ONPREMISE_PARAM'"
		},
		"LS_FILE_ONPREMISE_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "\\\\DESKTOP-NAFOKAU\\Curso_ADF"
		},
		"LS_FILE_ONPREMISE_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "treinamentosql"
		},
		"LS_FILE_ONPREMISE_PARAM_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "@{linkedService().host}"
		},
		"LS_FILE_ONPREMISE_PARAM_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "treinamentosql"
		},
		"LS_KEY_VAULT_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultgqtreinamentosql.vault.azure.net/"
		},
		"LS_SQLSERVER_ONPREMISE_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "constringsqlserveronpremise"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-treinamentosql_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_FILE_ONPREMISE_password": {
						"value": "[parameters('LS_FILE_ONPREMISE_password')]"
					},
					"LS_FILE_ONPREMISE_PARAM_password": {
						"value": "[parameters('LS_FILE_ONPREMISE_PARAM_password')]"
					},
					"LS_SQLSERVER_ONPREMISE_PARAM_connectionString": {
						"value": "[parameters('LS_SQLSERVER_ONPREMISE_PARAM_connectionString')]"
					},
					"LS_AZURE_SQL_connectionString": {
						"value": "[parameters('LS_AZURE_SQL_connectionString')]"
					},
					"LS_BLOB_connectionString": {
						"value": "[parameters('LS_BLOB_connectionString')]"
					},
					"LS_KEY_VAULT_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KEY_VAULT_properties_typeProperties_baseUrl')]"
					},
					"LS_FILE_ONPREMISE_properties_typeProperties_host": {
						"value": "[parameters('LS_FILE_ONPREMISE_properties_typeProperties_host')]"
					},
					"LS_FILE_ONPREMISE_properties_typeProperties_userId": {
						"value": "[parameters('LS_FILE_ONPREMISE_properties_typeProperties_userId')]"
					},
					"LS_FILE_ONPREMISE_PARAM_properties_typeProperties_host": {
						"value": "[parameters('LS_FILE_ONPREMISE_PARAM_properties_typeProperties_host')]"
					},
					"LS_FILE_ONPREMISE_PARAM_properties_typeProperties_userId": {
						"value": "[parameters('LS_FILE_ONPREMISE_PARAM_properties_typeProperties_userId')]"
					},
					"LS_SQLSERVER_ONPREMISE_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('LS_SQLSERVER_ONPREMISE_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-treinamentosql_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-treinamentosql_ArmTemplate_0')]"
			]
		}
	]
}